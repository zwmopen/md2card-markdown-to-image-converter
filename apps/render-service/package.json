{
  "name": "@md2card/render-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright-powered Markdown-to-image renderer for MD2Card",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.unit.test.ts",
    "test:render": "node --import tsx --test tests/render.e2e.test.ts",
    "check": "npm run type-check && npm test && npm run build",
    "check:e2e": "npm run check && npm run test:render"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "marked": "^15.0.12",
    "playwright": "1.61.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/sanitize-html": "^2.16.0",
    "tsx": "^4.20.6",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
